// ============================================================================
// SETUP: MOCKS AND MOCK DATA
// ============================================================================

/**
 * Mock colors object
 * 
 * PURPOSE: Represents the color palette passed from ThemeContext
 * This object is used consistently across all component tests to ensure
 * components accept and handle the colors prop correctly.
 * 
 * STRUCTURE:
 * - background: Main page background color
 * - surface: Card/elevated surface color
 * - border: Border and divider colors
 * - primary: Primary action color (buttons, links)
 * - secondary: Secondary action color
 * - text: Primary text color
 * - textSecondary: Secondary/muted text color
 * - error: Error state color
 * - success: Success state color
 * - warning: Warning state color
 * 
 * USAGE:
 * Pass mockColors to every component that accepts a colors prop
 * Example: <<PageName>Header colors={mockColors} />
 */
const mockColors = {
  background: '#ffffff',
  surface: '#f5f5f5',
  border: '#e0e0e0',
  primary: '#007bff',
  secondary: '#6c757d',
  text: '#000000',
  textSecondary: '#666666',
  error: '#dc3545',
  success: '#28a745',
  warning: '#ffc107',
};

/**
 * Helper function to render components with BrowserRouter
 * 
 * PURPOSE: Wraps component rendering with necessary providers
 * Required for components that use navigation (Link, useNavigate)
 * 
 * WHY WE NEED IT:
 * - React Router components require a Router context
 * - Without it, Link components will throw errors
 * - Simulates real app environment where Router wraps everything
 * 
 * USAGE:
 * Instead of: render(<MyComponent />)
 * Use: renderWithRouter(<MyComponent />)
 * 
 * EXAMPLE:
 * const { container } = renderWithRouter(
 *   <<PageName>Container colors={mockColors}>
 *     <Link to="/home">Home</Link>
 *   </<PageName>Container>
 * );
 */
const renderWithRouter = (component: React.ReactElement) => {
  return render(<BrowserRouter>{component}</BrowserRouter>);
};

